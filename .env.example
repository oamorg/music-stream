SERVICE_NAME=music-stream
APP_ENV=dev
HTTP_PORT=8080
SHUTDOWN_TIMEOUT=10s
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=168h
MANIFEST_URL_TTL=10m
AUTH_LOGIN_RATE_LIMIT=10
AUTH_LOGIN_RATE_WINDOW=1m
EVENT_RATE_LIMIT=120
EVENT_RATE_WINDOW=1m

DATABASE_URL=postgres://music:music@localhost:5432/music?sslmode=disable
REDIS_ADDR=localhost:6379

MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=music-stream
MEDIA_BASE_URL=http://localhost:8080/media
LOCAL_MEDIA_ROOT=.data/media
FFMPEG_BINARY=ffmpeg
WORKER_POLL_INTERVAL=5s

JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
